    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "즉시 조치가 필요한 hard action cue 개수입니다. exporter down, Chzzk wrapper non-success, missing intervals, Event ID 322, freshness threshold breach를 셉니다. Steam known caveat / partial-success caveat는 hard failure로 세지 않고 별도 attention/caveat signal로 봅니다.",
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 2
              }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 5,
        "x": 5,
        "y": 0
      },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value"
      },
      "pluginVersion": "11.4.0",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "(1 - (steam_observability_exporter_up or vector(0))) + (sum(chzzk_guarded_write_wrapper_latest_run_status{status=~\"partial_success|hard_failure|missing|unknown\"} == 1) or vector(0)) + (sum(chzzk_guarded_write_scheduler_recent_missing_intervals > 0) or vector(0)) + (sum(chzzk_guarded_write_scheduler_recent_new_instance_ignored_events > 0) or vector(0)) + (max((steam_db_dataset_freshness_age_seconds{dataset=~\"ccu_30m|price_1h\"} or chzzk_db_dataset_freshness_age_seconds) > bool 21600) or vector(0))",
          "instant": true,
          "legendFormat": "hard cues",
          "range": false,
          "refId": "A"
        }
      ],
      "title": "Action Needed",
      "type": "stat"
    },
